    if (!records.length) { showEmpty('inventory'); return; }
    document.getElementById('inventoryBody').innerHTML = records.map(r => {
      const branchName  = r.branch?.name  || r.branch_name  || '—';
      const productName = r.product?.name || r.product_name || '—';
      const thresh      = r.low_stock_threshold ?? r.threshold ?? 0;
      const isLow       = r.is_low ?? (r.stock <= thresh);
      return `
        <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
          <td class="td-sub px-4 py-3">${branchName}</td>
          <td class="td-main px-4 py-3">${productName}</td>
          <td class="td-amt px-4 py-3" style="${isLow ? 'color:#ff6b6b;' : ''}">${r.stock ?? '—'}</td>
          <td class="td-sub px-4 py-3">${thresh}</td>
          <td class="px-4 py-3">
            ${isLow ? `<span class="badge badge-critical">Low Stock</span>` : `<span class="badge badge-active">OK</span>`}
          </td>
        </tr>
      `;
    }).join('');
    showTable('inventory');
  } catch { showEmpty('inventory'); }
}

