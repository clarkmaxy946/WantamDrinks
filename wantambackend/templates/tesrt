<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>WantamDrinks — Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { head: ['Syne','sans-serif'], body: ['DM Sans','sans-serif'] },
          colors: {
            primary: '#0A2540', accent: '#00C896', accent2: '#00A3FF',
            muted: '#7A9AB0', wdtext: '#E8F4F8',
          },
          keyframes: {
            fadeUp:  { from:{ opacity:'0', transform:'translateY(20px)' }, to:{ opacity:'1', transform:'translateY(0)' } },
            shimmer: { '0%':{ backgroundPosition:'-200% 0' }, '100%':{ backgroundPosition:'200% 0' } },
            spin:    { to:{ transform:'rotate(360deg)' } },
            btnGlow: { '0%,100%':{ boxShadow:'0 0 20px rgba(128,0,255,0.5),0 0 60px rgba(0,163,255,0.3)' }, '50%':{ boxShadow:'0 0 40px rgba(128,0,255,0.8),0 0 100px rgba(0,163,255,0.5)' } },
            pulse2:  { '0%,100%':{ opacity:'1', transform:'scale(1)' }, '50%':{ opacity:'0.4', transform:'scale(1.5)' } },
          },
          animation: {
            fadeUp:  'fadeUp 0.6s ease both',
            shimmer: 'shimmer 2s linear infinite',
            spin:    'spin 0.8s linear infinite',
            btnGlow: 'btnGlow 2.5s ease-in-out infinite',
            pulse2:  'pulse2 2s ease-in-out infinite',
          },
        }
      }
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #0A2540; color: #E8F4F8; overflow: hidden; height: 100vh; }

    .sb::-webkit-scrollbar { width: 4px; }
    .sb::-webkit-scrollbar-track { background: transparent; }
    .sb::-webkit-scrollbar-thumb { background: rgba(0,200,150,0.2); border-radius: 4px; }

    .bg-scene {
      position: absolute; inset: 0; z-index: 0;
      background: linear-gradient(135deg, #0A2540 0%, #0d3460 50%, #0A2540 100%);
    }
    .bg-overlay {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(135deg, rgba(10,37,64,0.85) 0%, rgba(10,37,64,0.6) 100%);
    }
    .bg-grid {
      position: absolute; inset: 0; z-index: 1;
      background-image: linear-gradient(rgba(0,200,150,0.03) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(0,200,150,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 0.65rem 1rem; border-radius: 12px;
      font-size: 0.875rem; color: #7A9AB0;
      cursor: pointer; transition: all 0.2s;
      border: 1px solid transparent;
      text-decoration: none; user-select: none;
      background: none; width: 100%; text-align: left;
    }
    .nav-item:hover { background: rgba(0,200,150,0.07); border-color: rgba(0,200,150,0.18); color: #E8F4F8; }
    .nav-item.active { background: rgba(0,200,150,0.1); border-color: rgba(0,200,150,0.3); color: #00C896; }

    .logout-btn {
      display: flex; align-items: center; gap: 12px;
      padding: 0.65rem 1rem; border-radius: 12px;
      font-size: 0.875rem; color: rgba(255,107,107,0.75);
      cursor: pointer; transition: all 0.2s;
      border: 1px solid transparent; width: 100%;
      background: none;
    }
    .logout-btn:hover { background: rgba(255,107,107,0.08); border-color: rgba(255,107,107,0.22); color: #ff6b6b; }

    .stat-card {
      background: rgba(15,52,96,0.45);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(0,200,150,0.15);
      border-radius: 20px;
      padding: 1.5rem;
      animation: fadeUp 0.6s ease both;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
      position: relative; overflow: hidden;
    }
    .stat-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(0,200,150,0.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .stat-card:hover {
      border-color: rgba(0,200,150,0.35);
      box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 20px rgba(0,200,150,0.08);
      transform: translateY(-3px);
    }

    .stat-icon {
      width: 44px; height: 44px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .skeleton {
      background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      border-radius: 10px;
    }

    .notif-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #00C896; flex-shrink: 0;
      box-shadow: 0 0 6px rgba(0,200,150,0.6);
      animation: pulse2 2s ease-in-out infinite;
    }

    .alert-bar {
      border-radius: 10px; padding: 0.7rem 1rem;
      font-size: 0.84rem; display: none;
      align-items: center; gap: 8px; margin-bottom: 1rem;
    }
    .alert-bar.show { display: flex; }
    .alert-bar.error { background: rgba(255,107,107,0.1); border: 1px solid rgba(255,107,107,0.3); color: #ff9b9b; }
    .alert-bar.ok    { background: rgba(0,200,150,0.1);   border: 1px solid rgba(0,200,150,0.3);   color: #00C896; }

    #inlinePanel { display: none; }
    #inlinePanel.show { display: block; }
    #overviewPanel.hide { display: none; }

    .td-id    { font-family: monospace; font-size: 12px; color: #9BBFD6; }
    .td-main  { font-size: 13px; color: #E8F4F8; }
    .td-sub   { font-size: 12px; color: #B8D4E3; }
    .td-amt   { font-size: 13px; font-weight: 700; color: #E8F4F8; font-family: 'Syne', sans-serif; }
    .td-date  { font-size: 12px; color: #9BBFD6; white-space: nowrap; }
    .th-cell  { text-align: left; padding: 10px 16px; font-size: 11px; font-weight: 700;
                text-transform: uppercase; letter-spacing: 0.07em; color: #C0D8E8; }

    .badge {
      display: inline-flex; align-items: center;
      padding: 2px 8px; border-radius: 6px;
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .badge-critical { background: rgba(255,80,80,0.15); color: #ff6b6b; border: 1px solid rgba(255,80,80,0.3); }
    .badge-low      { background: rgba(255,180,0,0.12); color: #ffc107; border: 1px solid rgba(255,180,0,0.3); }
    .badge-resolved { background: rgba(0,200,150,0.1);  color: #00C896; border: 1px solid rgba(0,200,150,0.3); }
    .badge-pending  { background: rgba(255,180,0,0.12); color: #ffc107; border: 1px solid rgba(255,180,0,0.3); }
    .badge-completed{ background: rgba(0,200,150,0.1);  color: #00C896; border: 1px solid rgba(0,200,150,0.3); }
    .badge-failed   { background: rgba(255,80,80,0.15); color: #ff6b6b; border: 1px solid rgba(255,80,80,0.3); }
    .badge-active   { background: rgba(0,200,150,0.1);  color: #00C896; border: 1px solid rgba(0,200,150,0.3); }
    .badge-inactive { background: rgba(122,154,176,0.12); color: #7A9AB0; border: 1px solid rgba(122,154,176,0.25); }

    .panel-card {
      background: rgba(15,52,96,0.45);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(0,200,150,0.15);
      border-radius: 20px;
    }

    #sidebarOverlay { display: none; position: fixed; inset: 0; z-index: 25; background: rgba(0,0,0,0.5); }
    #sidebarOverlay.show { display: block; }

    @media (max-width: 768px) {
      body { overflow: auto; }
      #sidebar { position: fixed; left: -280px; top: 0; bottom: 0; z-index: 30; transition: left 0.3s ease; }
      #sidebar.open { left: 0; }
    }
    @media (min-width: 769px) { #mobileMenuBtn { display: none; } }

    .nav-section-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: rgba(122,154,176,0.5);
      padding: 0.5rem 1rem 0.25rem;
      font-family: 'Syne', sans-serif;
    }

    .spinner {
      border: 2px solid rgba(0,200,150,0.2);
      border-top-color: #00C896;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: inline-block;
    }

    .input-field {
      background: rgba(10,37,64,0.65);
      border: 1px solid rgba(0,200,150,0.15);
      border-radius: 10px; padding: 0.55rem 0.9rem;
      font-family: 'DM Sans', sans-serif; font-size: 0.84rem;
      color: #E8F4F8; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input-field:focus { border-color: #00C896; box-shadow: 0 0 0 3px rgba(0,200,150,0.1); }
    .input-field::placeholder { color: #4a7090; }

    .action-btn {
      padding: 0.5rem 1.1rem; border-radius: 10px; font-size: 0.82rem;
      font-family: 'Syne', sans-serif; font-weight: 700; cursor: pointer;
      transition: all 0.2s; border: 1px solid transparent;
    }
    .action-btn-primary {
      background: rgba(0,200,150,0.15); border-color: rgba(0,200,150,0.35); color: #00C896;
    }
    .action-btn-primary:hover { background: rgba(0,200,150,0.25); }
    .action-btn-danger {
      background: rgba(255,80,80,0.1); border-color: rgba(255,80,80,0.3); color: #ff6b6b;
    }
    .action-btn-danger:hover { background: rgba(255,80,80,0.2); }
    .action-btn-muted {
      background: rgba(122,154,176,0.1); border-color: rgba(122,154,176,0.2); color: #7A9AB0;
    }
    .action-btn-muted:hover { background: rgba(122,154,176,0.18); color: #E8F4F8; }

    .tab-btn {
      padding: 0.45rem 1rem; border-radius: 10px;
      font-size: 0.82rem; font-family: 'Syne', sans-serif; font-weight: 600;
      cursor: pointer; transition: all 0.2s; border: 1px solid transparent;
      color: #7A9AB0; background: transparent;
    }
    .tab-btn.active {
      background: rgba(0,200,150,0.12); border-color: rgba(0,200,150,0.3); color: #00C896;
    }
    .tab-btn:not(.active):hover { background: rgba(0,200,150,0.05); color: #E8F4F8; }

    .trend-up   { color: #00C896; }
    .trend-down { color: #ff6b6b; }
  </style>
</head>

<body class="flex h-screen overflow-hidden">

<div id="sidebarOverlay" onclick="closeMobileSidebar()"></div>

<!-- SIDEBAR -->
<aside id="sidebar" class="sb relative z-20 flex flex-col w-72 min-h-screen overflow-y-auto flex-shrink-0"
       style="background:rgba(6,22,42,0.97);border-right:1px solid rgba(0,200,150,0.1);">

  <div class="flex items-center gap-3 px-5 py-5 flex-shrink-0" style="border-bottom:1px solid rgba(0,200,150,0.1);">
    <div class="relative w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 overflow-hidden"
         style="background:linear-gradient(135deg,#00C896,#00A3FF);box-shadow:0 0 20px rgba(0,200,150,0.4);">
      <span class="font-head font-black text-sm" style="color:#0A2540;">WD</span>
      <div class="absolute inset-0" style="background:linear-gradient(45deg,transparent 40%,rgba(255,255,255,0.15) 50%,transparent 60%);animation:shimmer 3s infinite;background-size:200% 100%;"></div>
    </div>
    <div>
      <span style="font-family:Syne,sans-serif;font-weight:700;font-size:1.4rem;color:#f0e8ff">Wantam<span style="color:#b44fff">Drinks</span></span>
      <div style="font-size:10px;color:#00C896;font-family:Syne,sans-serif;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-top:1px;">Admin Console</div>
    </div>
  </div>

  <nav class="flex flex-col gap-0.5 px-3 pt-4 flex-1">
    <p class="nav-section-label">Overview</p>
    <button id="navDashboard" class="nav-item active" onclick="showOverview(this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      Dashboard
    </button>

    <p class="nav-section-label mt-3">Management</p>
    <button id="navUsers" class="nav-item" onclick="showPanel('users', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Users
    </button>
    <button id="navBranches" class="nav-item" onclick="showPanel('branches', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Branches
    </button>
    <button id="navProducts" class="nav-item" onclick="showPanel('products', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Products
    </button>
    <button id="navInventory" class="nav-item" onclick="showPanel('inventory', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="21 8 21 21 3 21 3 8"/>
        <rect x="1" y="3" width="22" height="5" rx="1"/>
        <line x1="10" y1="12" x2="14" y2="12"/>
      </svg>
      Inventory
    </button>
    <button id="navRestock" class="nav-item" onclick="showPanel('restock', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
      </svg>
      Restock
    </button>

    <p class="nav-section-label mt-3">Finance &amp; Ops</p>
    <button id="navTransactions" class="nav-item" onclick="showPanel('transactions', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="1" x2="12" y2="23"/>
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
      Transactions
    </button>
    <button id="navAnalytics" class="nav-item" onclick="showPanel('analytics', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="20" x2="18" y2="10"/>
        <line x1="12" y1="20" x2="12" y2="4"/>
        <line x1="6" y1="20" x2="6" y2="14"/>
      </svg>
      Analytics
    </button>
    <button id="navAlerts" class="nav-item" onclick="showPanel('alerts', this)">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      Alerts
      <span id="alertBadgeCount" class="ml-auto text-xs font-bold px-2 py-0.5 rounded-full hidden"
            style="background:rgba(255,80,80,0.2);color:#ff6b6b;border:1px solid rgba(255,80,80,0.3);">0</span>
    </button>
  </nav>

  <div class="px-3 mt-4 mb-2">
    <button class="logout-btn" onclick="handleLogout()">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Log Out
    </button>
  </div>

  <div class="mx-3 mb-4 rounded-2xl p-3 flex-shrink-0" style="background:rgba(10,37,64,0.6);border:1px solid rgba(0,200,150,0.12);">
    <div class="flex items-center gap-3">
      <div id="sidebarAvatar" class="w-9 h-9 rounded-xl flex items-center justify-center font-head font-bold text-sm flex-shrink-0"
           style="background:linear-gradient(135deg,#7B2FF7,#00A3FF);color:white;">A</div>
      <div class="min-w-0">
        <p id="sidebarName" class="font-head text-sm font-semibold text-wdtext truncate">Admin</p>
        <p class="text-xs" style="color:#00C896;">Staff · Administrator</p>
      </div>
    </div>
  </div>
</aside>

<!-- MAIN AREA -->
<div id="mainArea" class="relative flex-1 flex flex-col overflow-hidden">
  <div class="bg-scene"></div>
  <div class="bg-grid"></div>
  <div class="bg-overlay"></div>

  <header class="relative z-10 flex items-center justify-between px-5 md:px-8 pt-5 pb-2">
    <button id="mobileMenuBtn" class="mr-3 p-2 rounded-xl" style="background:rgba(15,52,96,0.5);border:1px solid rgba(0,200,150,0.15);" onclick="openMobileSidebar()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7A9AB0" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="flex-1">
      <h1 class="font-head font-black text-2xl md:text-3xl text-wdtext">
        Welcome back,&nbsp;<span id="usernameDisplay" style="background:linear-gradient(90deg,#00C896,#00A3FF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Admin</span>
      </h1>
      <p class="text-xs mt-0.5" style="color:#7A9AB0;" id="currentDateDisplay"></p>
    </div>
    <div class="flex items-center gap-3">
      <button onclick="loadOverviewData()" class="p-2 rounded-xl transition-all"
              style="background:rgba(15,52,96,0.5);border:1px solid rgba(0,200,150,0.15);" title="Refresh data">
        <svg id="refreshIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7A9AB0" stroke-width="2">
          <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
        </svg>
      </button>
      <div class="flex items-center gap-2 px-3 py-2 rounded-xl"
           style="background:rgba(15,52,96,0.5);border:1px solid rgba(0,200,150,0.15);">
        <div id="headerAvatar" class="w-8 h-8 rounded-lg flex items-center justify-center font-head font-bold text-sm"
             style="background:linear-gradient(135deg,#7B2FF7,#00A3FF);color:white;">A</div>
        <span class="text-sm hidden md:inline text-wdtext" id="headerUsername">Admin</span>
      </div>
    </div>
  </header>

  <main class="sb relative z-10 flex-1 overflow-y-auto px-5 md:px-8 pb-8 pt-4">

    <div class="alert-bar" id="alertBar"><span id="alertMsg"></span><button onclick="hideAlert()" class="ml-auto text-lg leading-none">✕</button></div>

    <!-- OVERVIEW / DASHBOARD -->
    <div id="overviewPanel">
      <div class="flex items-center gap-2 mb-5">
        <div class="notif-dot"></div>
        <p class="text-sm">
          <span style="color:#7A9AB0;">Now Viewing: </span>
          <span class="font-head font-semibold" style="color:#00C896;">Admin Dashboard</span>
        </p>
        <span class="ml-auto text-xs" style="color:#7A9AB0;">Live data · refreshes in <span id="countdownDisplay" style="color:#00C896;font-family:'Syne',sans-serif;font-weight:700;">30s</span></span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">

<div class="stat-card" style="animation-delay:0.3s">
          <div class="flex items-start justify-between mb-4">
            <div class="stat-icon" style="background:rgba(123,47,247,0.12);border:1px solid rgba(123,47,247,0.2);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b44fff" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <span class="text-xs font-head font-semibold px-2 py-1 rounded-lg" style="background:rgba(123,47,247,0.08);color:#b44fff;border:1px solid rgba(123,47,247,0.2);">TOTAL</span>
          </div>
          <p class="text-xs font-head font-bold uppercase tracking-widest mb-1" style="color:#7A9AB0;">Registered Users</p>
          <p id="statUsers" class="font-head font-black text-2xl text-wdtext mb-1">
            <span class="skeleton inline-block w-16 h-7 rounded"></span>
          </p>
          <p class="text-xs" style="color:#7A9AB0;" id="statUsersNote">all registered customers</p>
        </div>

        <div class="stat-card" style="animation-delay:0.1s">
