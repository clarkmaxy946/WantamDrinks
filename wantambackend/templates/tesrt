// ══════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════
async function loadAlerts() {
  showLoading('alerts');
  try {
    const resolved = document.getElementById('alertFilterResolved').value;
    const severity = document.getElementById('alertFilterSeverity').value;
    let url = '/api/admin/alerts/?';
    if (resolved !== '') url += `is_resolved=${resolved}&`;
    if (severity)        url += `severity=${severity}&`;
    const res  = await apiFetch(url);
    const data = await res.json();
    const alerts = data.alerts || [];
    if (!alerts.length) { showEmpty('alerts'); return; }
    document.getElementById('alertsBody').innerHTML = alerts.map(a => `
      <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
        <td class="td-id px-4 py-3">${a.id}</td>
        <td class="td-sub px-4 py-3">${a.branch_name}</td>
        <td class="td-main px-4 py-3">${a.product_name}</td>
        <td class="td-sub px-4 py-3 text-center">${a.stock_at_alert}</td>
        <td class="td-sub px-4 py-3 text-center" style="${a.current_stock <= a.threshold ? 'color:#ff6b6b;' : 'color:#00C896;'}">${a.current_stock}</td>
        <td class="px-4 py-3"><span class="badge badge-${(a.severity || '').toLowerCase()}">${a.severity}</span></td>
        <td class="px-4 py-3"><span class="badge ${a.is_resolved ? 'badge-resolved' : 'badge-critical'}">${a.is_resolved ? 'Resolved' : 'Open'}</span></td>
        <td class="td-sub px-4 py-3">${a.resolved_by || '—'}</td>
        <td class="td-date px-4 py-3">${fmtDate(a.created_at)}</td>
        <td class="px-4 py-3">
          ${!a.is_resolved
            ? `<button class="action-btn action-btn-primary text-xs" onclick="resolveAlert(${a.id}, this)">Resolve</button>`
            : `<span class="text-xs text-muted">Done</span>`}
        </td>
      </tr>
    `).join('');
    showTable('alerts');
  } catch { showEmpty('alerts'); }
}

async function resolveAlert(alertId, btn) {
  btn.disabled = true; btn.textContent = 'Resolving…';
  try {
    const res  = await apiFetch(`/api/admin/alerts/${alertId}/resolve/`, { method: 'POST' });
    const data = await res.json();
    if (res.ok) {
      showAlert(data.message || 'Alert resolved successfully.', 'ok');
      loadAlerts(); loadAlertsCard();
    } else {
      showAlert(data.error || data.message || 'Failed to resolve alert.', 'error');
      btn.disabled = false; btn.textContent = 'Resolve';
    }
  } catch {
    showAlert('Network error while resolving alert.', 'error');
    btn.disabled = false; btn.textContent = 'Resolve';
  }
}

