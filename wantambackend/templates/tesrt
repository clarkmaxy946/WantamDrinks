              <div class="spinner w-6 h-6 mx-auto mb-2"></div>
              <p class="text-xs text-muted">Loading…</p>
            </div>
            <div id="monthlySummaryTable" class="hidden overflow-x-auto">
              <table class="w-full border-collapse">
                <thead>
                  <tr style="border-bottom:1px solid rgba(0,200,150,0.1);">
                    <th class="th-cell">Branch</th>
                    <th class="th-cell">Month</th>
                    <th class="th-cell">Year</th>
                    <th class="th-cell">Units Sold</th>
                    <th class="th-cell">Revenue (KES)</th>
                  </tr>
                </thead>
                <tbody id="monthlySummaryBody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ALERTS PANEL -->
      <div id="alertsContent" class="hidden">
        <div class="flex items-center justify-between mb-5">
          <div>
            <h2 class="font-head font-bold text-xl text-wdtext">Stock Alerts</h2>
            <p class="text-xs text-muted mt-0.5">Low stock notifications from all branches</p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <select id="alertFilterResolved" class="input-field text-xs" onchange="loadAlerts()">
              <option value="false">Unresolved</option>
              <option value="true">Resolved</option>
              <option value="">All</option>
            </select>
            <select id="alertFilterSeverity" class="input-field text-xs" onchange="loadAlerts()">
              <option value="">All Severities</option>
              <option value="CRITICAL">Critical</option>
              <option value="LOW">Low</option>
            </select>
          </div>
        </div>
        <div class="panel-card p-5">
          <div id="alertsLoading" class="text-center py-10">
            <div class="spinner w-8 h-8 mx-auto mb-3"></div>
            <p class="text-sm text-muted">Loading alerts…</p>
          </div>
          <div id="alertsTable" class="hidden overflow-x-auto">
            <table class="w-full border-collapse">
              <thead>
                <tr style="border-bottom:1px solid rgba(0,200,150,0.1);">
                  <th class="th-cell">ID</th>
                  <th class="th-cell">Branch</th>
                  <th class="th-cell">Product</th>
                  <th class="th-cell">Stock at Alert</th>
                  <th class="th-cell">Current Stock</th>
                  <th class="th-cell">Severity</th>
                  <th class="th-cell">Status</th>
                  <th class="th-cell">Resolved By</th>
                  <th class="th-cell">Date</th>
                  <th class="th-cell">Action</th>
                </tr>
              </thead>
              <tbody id="alertsBody"></tbody>
            </table>
          </div>
          <p id="alertsEmpty" class="hidden text-center py-10 text-muted text-sm">No alerts found.</p>
        </div>
      </div>

    </div><!-- /inlinePanel -->
  </main>
</div>

<script>
// ══════════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════════
const API_BASE = 'http://127.0.0.1:8000';

function getToken() {
  return sessionStorage.getItem('access_token') || localStorage.getItem('access_token') || '';
}
function authHeaders() {
  return { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` };
}

async function apiFetch(path, opts = {}) {
  const res = await fetch(API_BASE + path, { headers: authHeaders(), ...opts });
  if (res.status === 401) {
    if (!window.location.pathname.startsWith('/login')) {
      sessionStorage.clear();
      localStorage.removeItem('access_token');
      localStorage.removeItem('refresh_token');
      showAlert('Session expired. Redirecting to login…', 'error');
      setTimeout(() => { window.location.href = '/login/'; }, 1800);
    }
    return res;
  }
  return res;
}

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  const token = sessionStorage.getItem('access_token') || localStorage.getItem('access_token') || '';
  if (!token) { window.location.href = '/login/'; return; }

  const username = sessionStorage.getItem('username') || localStorage.getItem('username') || 'Admin';
  const initial  = username.charAt(0).toUpperCase();
  document.getElementById('usernameDisplay').textContent = username;
  document.getElementById('headerUsername').textContent  = username;
  document.getElementById('sidebarName').textContent     = username;
  document.getElementById('headerAvatar').textContent    = initial;
  document.getElementById('sidebarAvatar').textContent   = initial;

  const now = new Date();
  document.getElementById('currentDateDisplay').textContent =
    now.toLocaleDateString('en-KE', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
  document.getElementById('analyticsMonth').value = now.getMonth() + 1;
  document.getElementById('analyticsYear').value  = now.getFullYear();

  loadOverviewData();
  startAutoRefresh();
});

// ══════════════════════════════════════════════
// AUTO-REFRESH
// ══════════════════════════════════════════════
const REFRESH_INTERVAL = 30;
let autoRefreshTimer = null, countdownTimer = null, countdown = REFRESH_INTERVAL;

function startAutoRefresh() {
  clearInterval(autoRefreshTimer); clearInterval(countdownTimer);
  countdown = REFRESH_INTERVAL; updateCountdownDisplay();
  countdownTimer = setInterval(() => {
    countdown--; updateCountdownDisplay();
    if (countdown <= 0) countdown = REFRESH_INTERVAL;
  }, 1000);
  autoRefreshTimer = setInterval(() => {
    if (!document.getElementById('overviewPanel').classList.contains('hide')) loadOverviewData();
  }, REFRESH_INTERVAL * 1000);
}

function updateCountdownDisplay() {
  const el = document.getElementById('countdownDisplay');
  if (el) el.textContent = countdown + 's';
}

// ══════════════════════════════════════════════
// OVERVIEW
// ══════════════════════════════════════════════
async function loadOverviewData() {
  const icon = document.getElementById('refreshIcon');
  icon.style.animation = 'spin 0.8s linear infinite';
  countdown = REFRESH_INTERVAL; updateCountdownDisplay();
  await Promise.allSettled([
    loadRevenueCard(), loadOrdersCard(), loadAlertsCard(),
    loadUsersCard(), loadRecentOrders(), loadAlertSummary(),
  ]);
  icon.style.animation = '';
}

async function loadRevenueCard() {
  try {
    const today = new Date().toISOString().split('T')[0];
    const res   = await apiFetch(`/api/admin/analytics/daily/summary/?date=${today}`);
    const data  = await res.json();
    if (res.ok) {
      const total = (data.summary || []).reduce((sum, b) => sum + (b.total_revenue || 0), 0);
      document.getElementById('statRevenue').innerHTML =
        `KES ${Number(total).toLocaleString('en-KE', { minimumFractionDigits:2, maximumFractionDigits:2 })}`;
      document.getElementById('statRevenueNote').textContent =
        `from ${data.total_branches || 0} branch${data.total_branches !== 1 ? 'es' : ''} · ${today}`;
    } else {
      document.getElementById('statRevenue').innerHTML = '<span style="color:#7A9AB0;font-size:0.9rem;">No data</span>';
    }
  } catch {
    document.getElementById('statRevenue').innerHTML = '<span style="color:#ff9b9b;font-size:0.9rem;">Error</span>';
  }
}

async function loadOrdersCard() {
  try {
    const today = new Date().toISOString().split('T')[0];
    const res   = await apiFetch(`/api/admin/orders/?date=${today}`);
    const data  = await res.json();
    if (res.ok) {
      const orders  = data.orders || [];
      const pending   = orders.filter(o => o.status === 'PENDING').length;
      const completed = orders.filter(o => o.status === 'COMPLETED').length;
      document.getElementById('statOrders').textContent = data.total_orders ?? orders.length;
      document.getElementById('statOrdersNote').innerHTML =
        `<span style="color:#ffc107;">PENDING: ${pending}</span> &nbsp;·&nbsp; <span style="color:#00C896;">COMPLETED: ${completed}</span>`;
    } else {
      document.getElementById('statOrders').innerHTML = '<span style="color:#7A9AB0;font-size:0.9rem;">No data</span>';
    }
  } catch {
    document.getElementById('statOrders').innerHTML = '<span style="color:#ff9b9b;font-size:0.9rem;">Error</span>';
  }
}

async function loadAlertsCard() {
  try {
    const res  = await apiFetch('/api/admin/alerts/summary/');
    const data = await res.json();
    if (res.ok) {
      document.getElementById('statAlerts').textContent = data.total_unresolved ?? '—';
      document.getElementById('statAlertsNote').innerHTML =
        `<span style="color:#ff6b6b;">CRITICAL: ${data.critical_count ?? 0}</span>&nbsp;·&nbsp;` +
        `<span style="color:#ffc107;">LOW: ${data.low_count ?? 0}</span>`;
      const badge = document.getElementById('alertBadgeCount');
      if (data.total_unresolved > 0) {
        badge.textContent = data.total_unresolved; badge.classList.remove('hidden');
      } else { badge.classList.add('hidden'); }
    }
  } catch {
    document.getElementById('statAlerts').innerHTML = '<span style="color:#ff9b9b;font-size:0.9rem;">Error</span>';
  }
}

async function loadUsersCard() {
  try {
    const res  = await apiFetch('/api/admin/users/');
    const data = await res.json();
    if (res.ok) {
      document.getElementById('statUsers').textContent = data.total_users ?? (data.users || []).length;
      const active = (data.users || []).filter(u => u.is_active).length;
      document.getElementById('statUsersNote').textContent = `${active} active · all registered customers`;
    }
  } catch {
    document.getElementById('statUsers').innerHTML = '<span style="color:#ff9b9b;font-size:0.9rem;">Error</span>';
  }
}

async function loadRecentOrders() {
  const tbody = document.getElementById('recentOrdersBody');
  try {
    const today = new Date().toISOString().split('T')[0];
    const res   = await apiFetch(`/api/admin/orders/?date=${today}`);
    const data  = await res.json();
    if (!res.ok || !(data.orders || []).length) {
      tbody.innerHTML = `<tr><td colspan="6" class="text-center py-8 text-muted text-sm">No orders today.</td></tr>`;
      return;
    }
    const rows = (data.orders || []).slice(0, 8);
    tbody.innerHTML = rows.map(o => `
      <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
        <td class="td-id px-4 py-3">${o.order_id}</td>
        <td class="td-sub px-4 py-3">${o.customer_id || o.customer || '—'}</td>
        <td class="td-sub px-4 py-3">${o.branch?.name || '—'}</td>
        <td class="td-amt px-4 py-3">KES ${Number(o.total_price || 0).toLocaleString('en-KE')}</td>
        <td class="px-4 py-3"><span class="badge badge-${(o.status || '').toLowerCase()}">${o.status || '—'}</span></td>
        <td class="td-date px-4 py-3">${fmtTime(o.created_at)}</td>
      </tr>
    `).join('');
  } catch {
    tbody.innerHTML = `<tr><td colspan="6" class="text-center py-8 text-muted text-sm">Failed to load orders.</td></tr>`;
  }
}

async function loadAlertSummary() {
  const container = document.getElementById('alertSummaryContent');
  const branchEl  = document.getElementById('branchesAffected');
  try {
    const res  = await apiFetch('/api/admin/alerts/summary/');
    const data = await res.json();
    if (!res.ok) throw new Error();
    container.innerHTML = `
      <div class="rounded-xl p-4 flex items-center gap-4" style="background:rgba(255,80,80,0.08);border:1px solid rgba(255,80,80,0.18);">
        <div class="text-3xl font-head font-black" style="color:#ff6b6b;">${data.critical_count ?? 0}</div>
        <div>
          <p class="text-sm font-head font-bold" style="color:#ff9b9b;">Critical</p>
          <p class="text-xs text-muted">Immediate action needed</p>
        </div>
      </div>
      <div class="rounded-xl p-4 flex items-center gap-4" style="background:rgba(255,193,7,0.08);border:1px solid rgba(255,193,7,0.2);">
        <div class="text-3xl font-head font-black" style="color:#ffc107;">${data.low_count ?? 0}</div>
        <div>
          <p class="text-sm font-head font-bold" style="color:#ffd54f;">Low Stock</p>
          <p class="text-xs text-muted">Monitor &amp; restock soon</p>
        </div>
      </div>
      <div class="rounded-xl p-4 flex items-center gap-4" style="background:rgba(0,200,150,0.06);border:1px solid rgba(0,200,150,0.15);">
        <div class="text-3xl font-head font-black text-wdtext">${data.total_unresolved ?? 0}</div>
        <div>
          <p class="text-sm font-head font-bold text-wdtext">Total Unresolved</p>
          <p class="text-xs text-muted">Pending resolution</p>
        </div>
      </div>
    `;
    const branches = data.branches_affected || [];
    branchEl.innerHTML = branches.length
      ? branches.map(b => `<span class="px-2 py-1 rounded-lg text-xs font-head font-semibold"
             style="background:rgba(0,200,150,0.1);border:1px solid rgba(0,200,150,0.2);color:#00C896;">${b}</span>`).join('')
      : `<span class="text-xs text-muted">None — all clear ✓</span>`;
  } catch {
    container.innerHTML = `<p class="text-sm text-muted text-center py-6">Failed to load alert summary.</p>`;
    branchEl.innerHTML  = `<span class="text-xs text-muted">—</span>`;
  }
}

// ══════════════════════════════════════════════
// PANEL NAVIGATION
// ══════════════════════════════════════════════
const ALL_NAV     = ['navDashboard','navUsers','navBranches','navProducts','navInventory','navRestock','navTransactions','navAnalytics','navAlerts'];
const ALL_CONTENT = ['usersContent','branchesContent','productsContent','inventoryContent','restockContent','transactionsContent','analyticsContent','alertsContent'];

function setNavActive(btn) {
  ALL_NAV.forEach(id => document.getElementById(id)?.classList.remove('active'));
  btn?.classList.add('active');
}
function showOverview(btn) {
  setNavActive(btn);
  document.getElementById('overviewPanel').classList.remove('hide');
  document.getElementById('inlinePanel').classList.remove('show');
  ALL_CONTENT.forEach(id => document.getElementById(id)?.classList.add('hidden'));
}
function showPanel(section, btn) {
  setNavActive(btn);
  document.getElementById('overviewPanel').classList.add('hide');
  document.getElementById('inlinePanel').classList.add('show');
  ALL_CONTENT.forEach(id => document.getElementById(id)?.classList.add('hidden'));
  const el = document.getElementById(section + 'Content');
  if (el) el.classList.remove('hidden');
  switch(section) {
    case 'users':        loadUsers();        break;
    case 'branches':     loadBranches();     break;
    case 'products':     loadProducts();     break;
    case 'inventory':    loadInventory();    break;
    case 'transactions': loadTransactions(); break;
    case 'analytics':    loadDailySummary(); break;
    case 'alerts':       loadAlerts();       break;
    case 'restock':      loadRestockPanel(); break;
  }
  closeMobileSidebar();
}
function closePanel() { showOverview(document.getElementById('navDashboard')); }

// ══════════════════════════════════════════════
// USERS
// ══════════════════════════════════════════════
async function loadUsers() {
  showLoading('users');
  try {
    const res  = await apiFetch('/api/admin/users/');
    const data = await res.json();
    const users = data.users || [];
    if (!users.length) { showEmpty('users'); return; }
    const myId = sessionStorage.getItem('user_id') || localStorage.getItem('user_id') || '';
    document.getElementById('usersBody').innerHTML = users.map(u => `
      <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
        <td class="td-id px-4 py-3">${u.user_id}</td>
        <td class="td-main px-4 py-3">${u.username}</td>
        <td class="td-sub px-4 py-3">${u.email}</td>
        <td class="td-sub px-4 py-3">${u.phone_number || '—'}</td>
        <td class="px-4 py-3"><span class="badge ${u.is_staff ? 'badge-critical' : 'badge-resolved'}">${u.is_staff ? 'Staff' : 'Customer'}</span></td>
        <td class="px-4 py-3"><span class="badge ${u.is_active ? 'badge-active' : 'badge-inactive'}">${u.is_active ? 'Active' : 'Inactive'}</span></td>
        <td class="td-sub px-4 py-3 text-center">${u.total_orders ?? '—'}</td>
        <td class="td-date px-4 py-3">${fmtDate(u.created_at)}</td>
        <td class="px-4 py-3">
          ${u.user_id !== myId
            ? `<button class="action-btn action-btn-danger text-xs" onclick="deleteUser('${u.user_id}', '${u.username}', this)">Delete</button>`
            : `<span class="text-xs text-muted">You</span>`}
        </td>
      </tr>
    `).join('');
    showTable('users');
  } catch { showEmpty('users'); }
}

function openAddUserModal() {
  ['newUserUsername','newUserEmail','newUserPhone','newUserPassword','newUserConfirm'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('addUserError').classList.add('hidden');
  document.getElementById('addUserModal').classList.remove('hidden');
}
function closeAddUserModal() { document.getElementById('addUserModal').classList.add('hidden'); }

async function submitAddUser(btn) {
  const username = document.getElementById('newUserUsername').value.trim();
  const email    = document.getElementById('newUserEmail').value.trim();
  const phone    = document.getElementById('newUserPhone').value.trim();
  const password = document.getElementById('newUserPassword').value;
  const confirm  = document.getElementById('newUserConfirm').value;
  const errEl    = document.getElementById('addUserError');
  errEl.classList.add('hidden');
  if (!username || !email || !phone || !password || !confirm) {
    errEl.textContent = 'All fields are required.'; errEl.classList.remove('hidden'); return;
  }
  if (password !== confirm) {
    errEl.textContent = 'Passwords do not match.'; errEl.classList.remove('hidden'); return;
  }
  btn.disabled = true; btn.textContent = 'Creating…';
  try {
    const res  = await apiFetch('/api/auth/register/', {
      method: 'POST',
      body: JSON.stringify({ username, email, phone_number: phone, password, confirm_password: confirm })
    });
    const data = await res.json();
    if (res.ok) {
      closeAddUserModal();
      showAlert(`User '${username}' created successfully.`, 'ok');
      loadUsers(); loadUsersCard();
    } else {
      const msgs = Object.values(data).flat().join(' ');
      errEl.textContent = msgs || 'Failed to create user.'; errEl.classList.remove('hidden');
    }
  } catch {
    errEl.textContent = 'Network error. Please try again.'; errEl.classList.remove('hidden');
  }
  btn.disabled = false; btn.textContent = 'Create User';
}

async function deleteUser(userId, username, btn) {
  if (!confirm(`Delete user '${username}'? This cannot be undone.`)) return;
  btn.disabled = true; btn.textContent = 'Deleting…';
  try {
    const res  = await apiFetch(`/api/admin/users/${userId}/`, { method: 'DELETE' });
    const data = await res.json();
    if (res.ok) {
      showAlert(data.message || `User '${username}' deleted.`, 'ok');
      loadUsers(); loadUsersCard();
    } else {
      showAlert(data.error || 'Failed to delete user.', 'error');
      btn.disabled = false; btn.textContent = 'Delete';
    }
  } catch {
    showAlert('Network error.', 'error');
    btn.disabled = false; btn.textContent = 'Delete';
  }
}

// ══════════════════════════════════════════════
// BRANCHES
// ══════════════════════════════════════════════
async function loadBranches() {
  showLoading('branches');
  try {
    const res  = await apiFetch('/api/admin/branches/');
    const data = await res.json();
    const branches = data.branches || [];
    if (!branches.length) { showEmpty('branches'); return; }
    document.getElementById('branchesBody').innerHTML = branches.map(b => {
      const alertCount = b.alert_count ?? 0;
      const toggleBtn = b.is_active
        ? `<button class="action-btn action-btn-muted text-xs" onclick="deactivateBranch('${b.branch_id}', '${b.name}', this)">Deactivate</button>`
        : `<button class="action-btn action-btn-primary text-xs" onclick="activateBranch('${b.branch_id}', '${b.name}', this)">Activate</button>`;
      const deleteBtn = !b.is_active
        ? `<button class="action-btn action-btn-danger text-xs" onclick="deleteBranch('${b.branch_id}', '${b.name}', this)">Delete</button>`
        : `<button class="action-btn text-xs" style="opacity:0.35;cursor:not-allowed;" disabled title="Deactivate first">Delete</button>`;
      return `
        <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
          <td class="td-id px-4 py-3">${b.branch_id}</td>
          <td class="td-main px-4 py-3">${b.name}</td>
          <td class="td-sub px-4 py-3">${b.location || '—'}</td>
          <td class="td-sub px-4 py-3">${b.manager_name || '—'}</td>
          <td class="px-4 py-3"><span class="badge ${b.is_active ? 'badge-active' : 'badge-inactive'}">${b.is_active ? 'Active' : 'Inactive'}</span></td>
          <td class="px-4 py-3">
            ${alertCount > 0
              ? `<span class="badge badge-critical">${alertCount} alert${alertCount !== 1 ? 's' : ''}</span>`
              : `<span class="text-xs" style="color:#00C896;">✓ Clear</span>`}
          </td>
          <td class="px-4 py-3 flex gap-2">${toggleBtn}${deleteBtn}</td>
        </tr>
      `;
    }).join('');
    showTable('branches');
  } catch { showEmpty('branches'); }
}

async function deactivateBranch(branchId, branchName, btn) {
  if (!confirm(`Deactivate branch '${branchName}'?\n\nIt will be hidden from customers and can be deleted afterward.`)) return;
  btn.disabled = true; btn.textContent = 'Deactivating…';
  try {
    const res  = await apiFetch(`/api/admin/branches/${branchId}/`, {
      method: 'PATCH',
      body: JSON.stringify({ is_active: false })
    });
    const data = await res.json();
    if (res.ok) {
      showAlert(data.message || `Branch '${branchName}' deactivated.`, 'ok');
      loadBranches();
    } else {
      showAlert(data.error || 'Failed to deactivate branch.', 'error');
      btn.disabled = false; btn.textContent = 'Deactivate';
    }
  } catch {
    showAlert('Network error.', 'error');
    btn.disabled = false; btn.textContent = 'Deactivate';
  }
}

async function activateBranch(branchId, branchName, btn) {
  if (!confirm(`Reactivate branch '${branchName}'?\n\nIt will become visible to customers again.`)) return;
  btn.disabled = true; btn.textContent = 'Activating…';
  try {
    const res  = await apiFetch(`/api/admin/branches/${branchId}/`, {
      method: 'PATCH',
      body: JSON.stringify({ is_active: true })
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      showAlert(data.message || `Branch '${branchName}' reactivated.`, 'ok');
      loadBranches();
    } else {
      showAlert(data.error || 'Failed to activate branch.', 'error');
      btn.disabled = false; btn.textContent = 'Activate';
    }
  } catch {
    showAlert('Network error.', 'error');
    btn.disabled = false; btn.textContent = 'Activate';
  }
}

// ═══════════════════════════════════════════════════════════════════
// ADD BRANCH MODAL — FIX 1
// openAddBranchModal: clear the new newBranchId field too
// submitAddBranch: read branch_id, validate it, include in POST body
// ═══════════════════════════════════════════════════════════════════
function openAddBranchModal() {
  ['newBranchId','newBranchName','newBranchLocation','newBranchManager','newBranchPhone'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('addBranchError').classList.add('hidden');
  document.getElementById('addBranchModal').classList.remove('hidden');
}
function closeAddBranchModal() { document.getElementById('addBranchModal').classList.add('hidden'); }

async function submitAddBranch(btn) {
  const branch_id    = document.getElementById('newBranchId').value.trim();
  const name         = document.getElementById('newBranchName').value.trim();
  const location     = document.getElementById('newBranchLocation').value.trim();
  const manager_name = document.getElementById('newBranchManager').value.trim();
  const manager_phone= document.getElementById('newBranchPhone').value.trim();
  const errEl        = document.getElementById('addBranchError');
  errEl.classList.add('hidden');

  if (!branch_id || !name || !location || !manager_name || !manager_phone) {
    errEl.textContent = 'All fields are required.'; errEl.classList.remove('hidden'); return;
  }

  btn.disabled = true; btn.textContent = 'Creating…';
  try {
    const res  = await apiFetch('/api/admin/branches/', {
      method: 'POST',
      body: JSON.stringify({ branch_id, name, location, manager_name, manager_phone, is_active: true })
    });
    const data = await res.json();
    if (res.ok) {
      closeAddBranchModal();
      showAlert(data.message || `Branch '${name}' created successfully.`, 'ok');
      loadBranches();
    } else {
      // Show the first validation message from the backend
      const msgs = typeof data === 'object'
        ? Object.entries(data).map(([k, v]) => `${k}: ${Array.isArray(v) ? v.join(' ') : v}`).join(' | ')
        : 'Failed to create branch.';
      errEl.textContent = msgs; errEl.classList.remove('hidden');
    }
  } catch {
    errEl.textContent = 'Network error. Please try again.'; errEl.classList.remove('hidden');
  }
  btn.disabled = false; btn.textContent = 'Create Branch';
}

async function deleteBranch(branchId, branchName, btn) {
  if (!confirm(`Delete branch '${branchName}'? This cannot be undone.`)) return;
  btn.disabled = true; btn.textContent = 'Deleting…';
  try {
    const res = await apiFetch(`/api/admin/branches/${branchId}/`, { method: 'DELETE' });
    // Handle both 200 (with JSON body) and 204 (empty body)
    if (res.ok) {
      let msg = `Branch '${branchName}' deleted.`;
      if (res.status !== 204) {
        const data = await res.json().catch(() => ({}));
        msg = data.message || msg;
      }
      showAlert(msg, 'ok');
      loadBranches();
    } else {
      const data = await res.json().catch(() => ({}));
      showAlert(data.error || 'Failed to delete. Ensure the branch is inactive first.', 'error');
      btn.disabled = false; btn.textContent = 'Delete';
    }
  } catch {
    showAlert('Network error.', 'error');
    btn.disabled = false; btn.textContent = 'Delete';
  }
}

