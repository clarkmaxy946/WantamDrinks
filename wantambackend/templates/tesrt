// ANALYTICS
// ══════════════════════════════════════════════
function switchAnalyticsTab(tab) {
  const isDaily = tab === 'daily';
  document.getElementById('analyticsDaily').classList.toggle('hidden', !isDaily);
  document.getElementById('analyticsMonthly').classList.toggle('hidden', isDaily);
  document.getElementById('tabAnalyticsDaily').classList.toggle('active', isDaily);
  document.getElementById('tabAnalyticsMonthly').classList.toggle('active', !isDaily);
  if (isDaily) loadDailySummary(); else loadMonthlySummary();
}

async function loadDailySummary() {
  const dateInput = document.getElementById('analyticsDate').value;
  const date      = dateInput || new Date().toISOString().split('T')[0];
  document.getElementById('dailySummaryLoading').classList.remove('hidden');
  document.getElementById('dailySummaryTable').classList.add('hidden');
  try {
    const res  = await apiFetch(`/api/admin/analytics/daily/summary/?date=${date}`);
    const data = await res.json();
    const rows = data.summary || [];
    if (!rows.length) {
      document.getElementById('dailySummaryLoading').innerHTML = `<p class="text-sm text-muted text-center py-4">No data for ${date}.</p>`;
      return;
    }
    document.getElementById('dailySummaryBody').innerHTML = rows.map(r => `
      <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02]">
        <td class="td-main px-4 py-3">${r.branch_name}</td>
        <td class="td-sub px-4 py-3">${r.date}</td>
        <td class="td-sub px-4 py-3">${(r.total_sold || 0).toLocaleString()}</td>
        <td class="td-amt px-4 py-3">KES ${Number(r.total_revenue || 0).toLocaleString('en-KE', {minimumFractionDigits:2})}</td>
      </tr>
    `).join('');
    document.getElementById('dailySummaryLoading').classList.add('hidden');
    document.getElementById('dailySummaryTable').classList.remove('hidden');
  } catch {
    document.getElementById('dailySummaryLoading').innerHTML = `<p class="text-sm text-muted text-center py-4">Failed to load.</p>`;
  }
}

async function loadMonthlySummary() {
  const month = document.getElementById('analyticsMonth').value;
