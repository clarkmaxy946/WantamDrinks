// RESTOCK
// ══════════════════════════════════════════════
async function loadRestockPanel() {
  const select    = document.getElementById('restockBranchSelect');
  const loadingEl = document.getElementById('restockBranchLoading');
  select.innerHTML = '<option value="">— Choose a branch —</option>';
  document.getElementById('restockProductsSection').classList.add('hidden');
  loadingEl.classList.remove('hidden');
  try {
    const res  = await apiFetch('/api/admin/branches/');
    const data = await res.json();
    const branches = data.branches || [];
    branches.forEach(b => {
      const opt = document.createElement('option');
      opt.value = b.branch_id;
      opt.textContent = b.name + (b.is_active ? '' : ' (Inactive)');
      select.appendChild(opt);
    });
  } catch {
    showAlert('Failed to load branches for restock.', 'error');
  }
  loadingEl.classList.add('hidden');
}

// ═══════════════════════════════════════════════════════════════════
// onRestockBranchChange — FIX 2
// BEFORE: /api/admin/inventory/branch/${branchId}/
//   → "branch" captured as branch_id, actual branchId as product_id
//   → hits AdminInventoryDetailView (PATCH only) → 405
//
// AFTER: /api/admin/inventory/${branchId}/
//   → correctly hits AdminBranchInventoryView (GET) → 200
//   → removed the broken 404-fallback block
// ═══════════════════════════════════════════════════════════════════
async function onRestockBranchChange() {
  const branchId = document.getElementById('restockBranchSelect').value;
  const section  = document.getElementById('restockProductsSection');
  if (!branchId) { section.classList.add('hidden'); return; }

  section.classList.remove('hidden');
  document.getElementById('restockProductsLoading').classList.remove('hidden');
  document.getElementById('restockProductsTable').classList.add('hidden');
  document.getElementById('restockProductsEmpty').classList.add('hidden');

  const branchName = document.getElementById('restockBranchSelect').selectedOptions[0].textContent;
  document.getElementById('restockBranchLabel').textContent = '— ' + branchName;

  try {
    // FIX: correct URL → AdminBranchInventoryView (GET supported)
    const res = await apiFetch(`/api/admin/inventory/${branchId}/`);

    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      const errMsg  = errData.error || errData.detail || `HTTP ${res.status}`;
      document.getElementById('restockProductsLoading').classList.add('hidden');
      showAlert(`Could not load inventory (${res.status}): ${errMsg}`, 'error');
      return;
    }

    const data = await res.json();
    // AdminBranchInventoryView returns a plain list directly
    const records = Array.isArray(data) ? data : (data.results || data.inventory || []);

    if (!records.length) {
      document.getElementById('restockProductsLoading').classList.add('hidden');
      document.getElementById('restockProductsEmpty').classList.remove('hidden');
      return;
    }

    document.getElementById('restockProductsBody').innerHTML = records.map(r => {
      const stock    = r.stock ?? 0;
      const thresh   = r.low_stock_threshold ?? 0;
      const isLow    = r.is_low ?? (stock <= thresh);
      const prodId   = r.product?.product_id ?? '';
      const prodName = r.product?.name ?? '—';
      const safeName = prodName.replace(/'/g, "\\'");
      return `
        <tr style="border-bottom:1px solid rgba(0,200,150,0.06);" class="hover:bg-white/[0.02] transition-colors">
          <td class="td-main px-4 py-3">${prodName}</td>
          <td class="td-amt px-4 py-3" style="${isLow ? 'color:#ff6b6b;' : ''}">${stock}</td>
          <td class="td-sub px-4 py-3">${thresh}</td>
          <td class="px-4 py-3">
            ${isLow ? `<span class="badge badge-critical">Low</span>` : `<span class="badge badge-active">OK</span>`}
          </td>
          <td class="px-4 py-3">
            <input type="number" min="1" placeholder="Units"
              id="restockQty_${prodId}"
              class="input-field text-xs w-24" style="padding:0.4rem 0.6rem;"/>
          </td>
          <td class="px-4 py-3">
            <button class="action-btn action-btn-primary text-xs"
              onclick="submitRestock('${branchId}', '${prodId}', '${safeName}', this)">
              Restock
            </button>
          </td>
        </tr>
      `;
    }).join('');

    document.getElementById('restockProductsLoading').classList.add('hidden');
    document.getElementById('restockProductsTable').classList.remove('hidden');
  } catch(e) {
    console.error('Restock load error:', e);
    document.getElementById('restockProductsLoading').classList.add('hidden');
    showAlert('Failed to load inventory for this branch.', 'error');
  }
}

async function submitRestock(branchId, productId, productName, btn) {
  const qtyInput = document.getElementById(`restockQty_${productId}`);
  const qty = parseInt(qtyInput?.value, 10);
  if (!qty || qty < 1) { showAlert('Please enter a valid quantity (minimum 1).', 'error'); return; }
  btn.disabled = true; btn.textContent = 'Restocking…';
  try {
    const res  = await apiFetch(`/api/admin/inventory/${branchId}/${productId}/restock/`, {
      method: 'POST',
      body: JSON.stringify({ quantity: qty })
    });
    const data = await res.json();
    if (res.ok) {
      showAlert(data.message || `${productName} restocked. New stock: ${data.current_stock}`, 'ok');
      if (qtyInput) qtyInput.value = '';
      onRestockBranchChange();
      loadAlertsCard();
    } else {
      const errMsg = data.error || data.detail || Object.values(data).flat().join(' ') || 'Restock failed.';
      showAlert(errMsg, 'error');
      btn.disabled = false; btn.textContent = 'Restock';
    }
  } catch(e) {
    console.error('Restock submit error:', e);
    showAlert('Network error during restock.', 'error');
    btn.disabled = false; btn.textContent = 'Restock';
  }
}

// ══════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════
function showLoading(section) {
  document.getElementById(section + 'Loading').classList.remove('hidden');
  document.getElementById(section + 'Table').classList.add('hidden');
  document.getElementById(section + 'Empty')?.classList.add('hidden');
}
function showTable(section) {
  document.getElementById(section + 'Loading').classList.add('hidden');
  document.getElementById(section + 'Table').classList.remove('hidden');
  document.getElementById(section + 'Empty')?.classList.add('hidden');
}
function showEmpty(section) {
  document.getElementById(section + 'Loading').classList.add('hidden');
  document.getElementById(section + 'Table').classList.add('hidden');
  document.getElementById(section + 'Empty')?.classList.remove('hidden');
}
function showAlert(msg, type = 'ok') {
  const bar = document.getElementById('alertBar');
  document.getElementById('alertMsg').textContent = msg;
  bar.className = `alert-bar show ${type}`;
  setTimeout(hideAlert, 5000);
}
function hideAlert() { document.getElementById('alertBar').classList.remove('show'); }

function fmtDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-KE', { day:'2-digit', month:'short', year:'numeric' });
}
function fmtTime(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleTimeString('en-KE', { hour:'2-digit', minute:'2-digit' });
}
function fmtDateTime(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('en-KE', { day:'2-digit', month:'short' }) + ' ' +
         d.toLocaleTimeString('en-KE', { hour:'2-digit', minute:'2-digit' });
}

function openMobileSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('sidebarOverlay').classList.add('show');
}
function closeMobileSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
}

function handleLogout() {
  sessionStorage.clear();
  localStorage.removeItem('access_token');
  localStorage.removeItem('refresh_token');
  localStorage.removeItem('username');
  localStorage.removeItem('user_id');
  localStorage.removeItem('is_staff');
  window.location.href = '/login/';
}
